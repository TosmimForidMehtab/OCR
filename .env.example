# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false

# ── OCR ───────────────────────────────────────────────────────────────────────
# Comma-separated language codes. Supported: en, hi, mr
OCR_DEFAULT_LANGS=en
OCR_CONFIDENCE_THRESHOLD=0.4
OCR_GPU=false

OCR_LINE_GROUP_RATIO=0.015
OCR_MIN_DIMENSION=1000
OCR_DESKEW_LIMIT=45
# PDF Output
PDF_FONT_NAME=NotoSans
PDF_FONT_SIZE=11
PDF_TEXT_OPACITY=0.0

# ── File handling ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
TEMP_DIR=/tmp/ocr_uploads

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=json
